#!/bin/bash

# 🤖 Простой интерфейс для создания новых агентов
# Используй: ./new-agent
# или просто: new-agent (если добавишь в PATH)

echo ""
echo "╔════════════════════════════════════════╗"
echo "║   🤖 СОЗДАНИЕ НОВОГО АГЕНТА            ║"
echo "╚════════════════════════════════════════╝"
echo ""

# Шаг 1: Имя агента
echo "Давай создадим нового агента!"
echo ""
echo "📝 Как его назвать? (одно слово, латиница)"
echo "   Примеры: optimizer, debugger, analyzer, formatter"
echo ""
read -p "Название: " NAME

if [ -z "$NAME" ]; then
  echo "❌ Ошибка: введи название!"
  exit 1
fi

# Шаг 2: Описание
echo ""
echo "📝 Для чего этот агент? (что он делает?)"
echo "   Пример: Оптимизирует код на производительность"
echo ""
read -p "Описание: " DESCRIPTION

if [ -z "$DESCRIPTION" ]; then
  echo "❌ Ошибка: введи описание!"
  exit 1
fi

# Шаг 3: Сложность
echo ""
echo "📊 Насколько сложная его работа?"
echo ""
echo "  1. 🟢 Простая (анализирует, читает, ищет)"
echo "  2. 🟡 Средняя (генерирует идеи, критикует)"
echo "  3. 🔴 Сложная (глубокий анализ, синтез всего)"
echo ""
read -p "Выбери (1/2/3): " EFFORT_NUM

case $EFFORT_NUM in
  1) EFFORT="low" ;;
  2) EFFORT="medium" ;;
  3) EFFORT="high" ;;
  *) EFFORT="medium" ;;
esac

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ Создаю агента..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Вызов основного скрипта
bash ./create-agent.sh "$NAME" "$DESCRIPTION" "$EFFORT"

# Если успешно
if [ $? -eq 0 ]; then
  echo ""
  echo "╔════════════════════════════════════════╗"
  echo "║  ✅ АГЕНТ ГОТОВ!                       ║"
  echo "╚════════════════════════════════════════╝"
  echo ""
  echo "🎯 Что дальше?"
  echo ""
  echo "1️⃣ Отредактируй инструкции агента:"
  echo "   Открой: .claude/agents/$NAME/$NAME.md"
  echo ""
  echo "2️⃣ Заполни что-то вроде этого:"
  echo "   - Что агент должен делать на каждом шаге"
  echo "   - Какие данные он получает входящие"
  echo "   - Какой формат вывода ты хочешь"
  echo ""
  echo "3️⃣ Используй агента:"
  echo "   @\"$NAME\" [твой запрос]"
  echo ""
  echo "ℹ️ Агент автоматически получит:"
  echo "   ✓ Бесплатный поиск (DuckDuckGo)"
  echo "   ✓ Бесплатные нейросети (Ollama)"
  echo "   ✓ Все навыки других агентов"
  echo "   ✓ Все новые фичи (когда добавим)"
  echo ""
  echo "💰 Стоимость: $0.00"
  echo ""
else
  echo "❌ Ошибка при создании агента"
  exit 1
fi
